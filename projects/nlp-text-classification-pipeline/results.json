      "ngram_range": "(1, 2)",
      "notes": "Best performer; fast training and inference"
    },
    "logistic_regression": {
      "accuracy": 0.6676,
      "precision": 0.6762,
      "recall": 0.6676,
      "f1": 0.6649,
      "notes": "Strong baseline; interpretable weights"
    },
    "linear_svm": {
      "accuracy": 0.6642,
      "precision": 0.6671,
      "recall": 0.6642,
      "f1": 0.6624,
      "notes": "Margin-based; competitive"
